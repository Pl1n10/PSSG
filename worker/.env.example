# === PSSG Worker Secrets ===
# Set these via: wrangler secret put SECRET_NAME

# Google Service Account JSON key (entire JSON, one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Google Sheets spreadsheet ID (from the URL)
SHEET_ID=1ABCxyz123...

# Allowed frontend origin (your Netlify URL)
ALLOWED_ORIGIN=https://petsittingsgc.it

# Random salt for hashing IPs (generate with: openssl rand -hex 32)
IP_HASH_SALT=change-me-to-a-random-string

# Email notification recipient
EMAIL_TO=petsittingsangiorgioacremano@gmail.com

# SendGrid API key (get from sendgrid.com)
SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# SendGrid verified sender email
EMAIL_FROM=noreply@petsittingsgc.it
